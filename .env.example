# Database
DATABASE_URL=postgresql://hermes_user:hermes_password@localhost:5432/hermes_db

# Frontend / CORS
FRONTEND_ORIGIN=http://localhost:5173

# Clerk backend auth
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----\nreplace_me\n-----END PUBLIC KEY-----
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# --- Shared LM Studio transport ---
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

# --- Local ingestion profile (structured extraction) ---
INGESTION_MODEL_PROVIDER=lm_studio
INGESTION_MODEL_NAME=
INGESTION_MODEL_TIMEOUT_SECONDS=30

# --- Local agent profile (Smart Comms & lighter agent tasks) ---
# May point to the same physical model as INGESTION_MODEL_NAME.
LOCAL_AGENT_MODEL_PROVIDER=lm_studio
LOCAL_AGENT_MODEL_NAME=
LOCAL_AGENT_MODEL_TIMEOUT_SECONDS=60
LOCAL_AGENT_MODEL_TEMPERATURE=0.7
LOCAL_AGENT_MODEL_MAX_TOKENS=500

# --- Cloud reasoning profile (orchestrator, carrier ranking, monitoring) ---
# Provider slug: openrouter (default)
REASONING_MODEL_PROVIDER=openrouter
REASONING_MODEL_NAME=
# OpenRouter API key (required for cloud reasoning)
REASONING_MODEL_API_KEY=
REASONING_MODEL_BASE_URL=https://openrouter.ai/api/v1
REASONING_MODEL_TIMEOUT_SECONDS=60
REASONING_MODEL_TEMPERATURE=0.3
REASONING_MODEL_MAX_TOKENS=1024

# --- Monitoring map / routing ---
MONITORING_GEOCODING_PROVIDER=opencage
MONITORING_GEOCODING_API_KEY=
MONITORING_ROUTING_PROVIDER=openrouteservice
MONITORING_ROUTING_API_KEY=
MONITORING_ROUTING_BASE_URL=https://api.openrouteservice.org
MONITORING_ROUTE_PROFILE=driving-hgv

# --- ChromaDB vector store ---
CHROMA_HOST=http://localhost:8001
